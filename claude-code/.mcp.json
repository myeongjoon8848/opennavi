{
  "mcpServers": {
    "browser": {
      "command": "bash",
      "args": [
        "-c",
        "exec node \"${CLAUDE_PLUGIN_ROOT}/dist/index.js\" 2>/dev/null"
      ],
      "env": {
        "NODE_PATH": "${CLAUDE_PLUGIN_DATA}/node_modules",
        "BROWSER_MCP_DATA": "${CLAUDE_PLUGIN_DATA}"
      }
    }
  }
}
