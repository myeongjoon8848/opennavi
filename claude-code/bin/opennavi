#!/usr/bin/env bash
# opennavi — OpenNavi Registry client
set -euo pipefail

NAVI_REGISTRY="${NAVI_REGISTRY_URL:-http://3.34.59.144:3456}"
NAVI_TIMEOUT=5

_extract_domain() {
  echo "$1" | awk -F/ '{print $3}'
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  query)
    url="${1:?Usage: opennavi query <url>}"
    domain=$(_extract_domain "$url")
    curl -sf --max-time "$NAVI_TIMEOUT" "$NAVI_REGISTRY/api/v1/sites/$domain" 2>/dev/null || echo ""
    ;;

  save)
    domain="${1:?Usage: opennavi save <domain> <json>}"
    json="${2:?Usage: opennavi save <domain> <json>}"
    result=$(curl -sf --max-time "$NAVI_TIMEOUT" -X PUT \
      "$NAVI_REGISTRY/api/v1/sites/$domain" \
      -H "Content-Type: application/json" \
      -d "$json" 2>/dev/null) || result='{"error":"registry_unavailable"}'
    echo "$result"
    ;;

  update-page)
    domain="${1:?Usage: opennavi update-page <domain> <pageId> <json>}"
    pageId="${2:?Usage: opennavi update-page <domain> <pageId> <json>}"
    json="${3:?Usage: opennavi update-page <domain> <pageId> <json>}"
    result=$(curl -sf --max-time "$NAVI_TIMEOUT" -X PATCH \
      "$NAVI_REGISTRY/api/v1/sites/$domain/pages/$pageId" \
      -H "Content-Type: application/json" \
      -d "$json" 2>/dev/null) || result='{"error":"registry_unavailable"}'
    echo "$result"
    ;;

  verify)
    domain="${1:?Usage: opennavi verify <domain>}"
    result=$(curl -sf --max-time "$NAVI_TIMEOUT" -X PATCH \
      "$NAVI_REGISTRY/api/v1/sites/$domain/verify" 2>/dev/null) || result='{"error":"registry_unavailable"}'
    echo "$result"
    ;;

  help|*)
    cat <<'USAGE'
opennavi — OpenNavi Registry client

Commands:
  query <url>                          Get site map from registry
  save <domain> <json>                 Save site map to registry
  update-page <domain> <pageId> <json> Update single page
  verify <domain>                      Confirm map is accurate

Environment:
  NAVI_REGISTRY_URL  Registry URL (default: http://3.34.59.144:3456)
USAGE
    ;;
esac
